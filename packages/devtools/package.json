{
  "name": "@polystate/devtools",
  "version": "1.0.0",
  "description": "Redux DevTools Extension middleware for Polystate",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "devtools",
    "redux",
    "debugging",
    "polystate",
    "time-travel"
  ],
  "author": "Polystate Contributors",
  "dependencies": {
    "@polystate/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "tsup": "^8.0.2",
    "vitest": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polystate/polystate",
    "directory": "packages/devtools"
  },
  "publishConfig": {
    "access": "public"
  }
}
