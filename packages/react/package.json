{
  "name": "@polystate/react",
  "version": "0.1.0",
  "description": "React 18+ hooks for Polystate state management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --external react",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "hooks",
    "state-management",
    "store",
    "polystate"
  ],
  "author": "Polystate Contributors",
  "license": "MIT",
  "dependencies": {
    "@polystate/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/jest-dom": "^6.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.3.3",
    "tsup": "^8.0.2",
    "vitest": "^1.1.0",
    "jsdom": "^23.0.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polystate/polystate",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}