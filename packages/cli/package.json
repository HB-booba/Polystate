{
  "name": "@polystate/cli",
  "version": "0.1.0",
  "description": "CLI tool for Polystate code generation",
  "main": "./dist/index.js",
  "bin": {
    "polystate": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format cjs,esm --dts --sourcemap && tsup src/index.ts --format cjs,esm --dts --sourcemap",
    "test": "vitest",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "polystate",
    "code-generation",
    "cli",
    "react",
    "angular"
  ],
  "author": "Polystate Contributors",
  "license": "MIT",
  "dependencies": {
    "@polystate/definition": "workspace:*",
    "@polystate/generator-angular": "workspace:*",
    "@polystate/generator-react": "workspace:*",
    "commander": "^11.0.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polystate/polystate",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  }
}