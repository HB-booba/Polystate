{
  "name": "@polystate/definition",
  "version": "0.1.0",
  "description": "Framework-agnostic store definitions for Polystate code generation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "dev": "tsup --watch"
  },
  "keywords": [
    "polystate",
    "state-management",
    "code-generation",
    "react",
    "angular"
  ],
  "author": "Polystate Contributors",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  }
}
