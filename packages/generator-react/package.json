{
  "name": "@polystate/generator-react",
  "version": "1.0.0",
  "description": "React Redux code generator for Polystate store definitions",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "test": "vitest",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": [
    "polystate",
    "code-generation",
    "react",
    "redux"
  ],
  "author": "Polystate Contributors",
  "dependencies": {
    "@polystate/definition": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polystate/polystate",
    "directory": "packages/generator-react"
  },
  "publishConfig": {
    "access": "public"
  }
}
