{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/npm.json",
  "npmScope": "polystate",
  "sourceRoot": "packages",
  "defaultBase": "main",
  "defaultRelease": {
    "releaseTags": {
      "includeSourceCommit": false
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "lint": {
      "cache": true
    }
  }
}