{
  "name": "polystate",
  "version": "0.0.1",
  "description": "Framework-agnostic state management library with native React and Angular support",
  "private": true,
  "type": "module",
  "scripts": {
    "nx": "nx",
    "start": "nx serve",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "nx run-many --target=dev --all --parallel",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "release": "node scripts/release.mjs",
    "fix-workspace-deps": "node scripts/fix-workspace-deps.mjs",
    "restore-workspace-deps": "node scripts/fix-workspace-deps.mjs --restore"
  },
  "devDependencies": {
    "@angular/core": "^17.3.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.1",
    "@nx/angular": "^18.0.0",
    "@nx/devkit": "^18.0.0",
    "@nx/js": "^18.0.0",
    "@nx/react": "^18.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jsdom": "^23.0.1",
    "nx": "^18.0.0",
    "prettier": "^3.1.1",
    "rxjs": "^7.8.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ]
}